{
  /**
   * ==================== Node.js 环境 TypeScript 配置 ====================
   *
   * 面向 Node.js 环境的配置文件（vite.config.ts、vitest.config.ts 等）。
   * 继承 @tsconfig/node24 预设配置。
   *
   * 关键配置：
   *   module: "preserve"           → 保留源码中的模块语法（交给打包工具处理）
   *   moduleResolution: "bundler"  → 打包器风格的模块解析（支持 .vue、省略扩展名等）
   *   noEmit: true                 → 只做类型检查，不输出编译产物
   *   types: ["node"]              → 仅加载 Node.js 类型定义（避免加载多余 @types 包）
   */
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "playwright.config.*",
    "eslint.config.*"
  ],
  "compilerOptions": {
    // 保留模块语法（Vite 负责转译，tsc 不介入）
    "module": "preserve",
    "moduleResolution": "bundler",

    // 仅加载 Node.js 类型，避免自动加载所有 @types/* 包
    "types": ["node"],

    // 不输出编译产物（纯类型检查）
    "noEmit": true,

    // 增量编译缓存位置
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
