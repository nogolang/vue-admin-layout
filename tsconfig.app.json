{
  /**
   * ==================== 应用代码 TypeScript 配置 ====================
   *
   * 面向浏览器环境的 Vue 应用代码。
   * 继承 @vue/tsconfig/tsconfig.dom.json 预设配置。
   *
   * 关键配置：
   *   noUncheckedIndexedAccess → 对数组/对象索引增加 undefined 检查（更安全）
   *   paths['@/*']             → 路径别名：@ → src/（与 vite.config.ts 中的 alias 对应）
   *   tsBuildInfoFile          → 增量编译缓存文件（放在 node_modules/.tmp 避免污染根目录）
   */
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // 启用严格的索引访问检查
    // 例如：arr[0] 的类型是 T | undefined，必须处理 undefined 的情况
    "noUncheckedIndexedAccess": true,

    // 路径映射（与 vite.config.ts 中的 resolve.alias 保持一致）
    "paths": {
      "@/*": ["./src/*"]
    },

    // 增量编译信息文件路径
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
